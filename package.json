{
  "name": "mega-event",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "eslint": "eslint \"{cypress,src}/**/*.{js,ts,tsx}\"",
    "eslint:fix": "eslint \"{cypress,src}/**/*.{js,ts,tsx}\" --fix",
    "stylelint": "stylelint \"src/**/*.scss\"",
    "stylelint:fix": "stylelint \"src/**/*.scss\" --fix",
    "prettier": "prettier \"{cypress,src}/**/*.{js,ts,tsx,json}\" --write",
    "prettier:styles": "prettier \"src/**/*.scss\" --write",
    "format": "yarn eslint:fix && stylelint:fix && prettier && prettier:styles",
    "reinstall-modules": "rm -rf ./node_modules && yarn cache clean && yarn install"
  },
  "dependencies": {
    "@reduxjs/toolkit": "1.9.3",
    "classnames": "2.3.2",
    "date-fns": "2.29.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "8.0.5",
    "react-router-dom": "6.9.0",
    "sass": "1.60.0"
  },
  "devDependencies": {
    "@types/cypress": "1.1.3",
    "@types/react": "18.0.29",
    "@types/react-dom": "18.0.11",
    "@typescript-eslint/eslint-plugin": "5.56.0",
    "@typescript-eslint/parser": "5.56.0",
    "@vitejs/plugin-react": "3.1.0",
    "cypress": "13.6.0",
    "cypress-vite": "1.5.0",
    "eslint": "8.36.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-config-react": "1.1.7",
    "eslint-plugin-cypress": "2.15.1",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-prettier": "5.1.2",
    "eslint-plugin-promise": "6.1.1",
    "eslint-plugin-react": "7.32.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "lefthook": "1.3.8",
    "prettier": "2.8.7",
    "stylelint": "15.3.0",
    "stylelint-config-idiomatic-order": "10.0.0",
    "stylelint-config-standard-scss": "7.0.1",
    "stylelint-order": "6.0.3",
    "stylelint-scss": "4.5.0",
    "typescript": "5.0.2",
    "vite": "4.2.1",
    "vite-plugin-devcert": "1.0.4"
  }
}
